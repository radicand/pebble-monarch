[
  {
    "type": "heading",
    "defaultValue": "Monarch Net Worth"
  },
  {
    "type": "text",
    "defaultValue": "Enter your Monarch credentials so your watch can fetch your net worth."
  },
  {
    "type": "section",
    "items": [
      {
        "type": "heading",
        "defaultValue": "Account"
      },
      {
        "type": "input",
        "messageKey": "EMAIL",
        "label": "Email",
        "defaultValue": "",
        "attributes": {
          "type": "email",
          "placeholder": "you@example.com"
        }
      },
      {
        "type": "input",
        "messageKey": "PASSWORD",
        "label": "Password",
        "defaultValue": "",
        "attributes": {
          "type": "password",
          "placeholder": "Your Monarch password"
        }
      },
      {
        "type": "input",
        "messageKey": "OTP_SEED",
        "label": "OTP Seed",
        "defaultValue": "",
        "attributes": {
          "type": "text",
          "placeholder": "Base32 seed or otpauth:// URL"
        }
      }
    ]
  },
  {
    "type": "section",
    "items": [
      {
        "type": "heading",
        "defaultValue": "Refresh"
      },
      {
        "type": "slider",
        "messageKey": "REFRESH_HOURS",
        "label": "Auto-refresh (hours)",
        "defaultValue": 12,
        "min": 6,
        "max": 24,
        "step": 4
      }
    ]
  },
  {
    "type": "text",
    "defaultValue": "<small>Credentials and OTP seed are stored on your phone and sent directly to Monarch's API. You can paste either the raw Base32 seed or a full otpauth:// URL from your authenticator setup.</small>"
  },
  {
    "type": "submit",
    "defaultValue": "Save"
  }
]
